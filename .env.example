# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (Railway PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/shiftmia

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PLATFORM_FEE_PERCENT=15

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxx
EMAIL_FROM=noreply@shiftmia.com
SMTP_HOST=smtp.sendgrid.net

# ─── File Uploads ─────────────────────────────────────────────────────────────
# Leave blank for local disk storage (dev)
# Set for Cloudinary production uploads:
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── Frontend ─────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxYYY
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Frontend env (client/.env) ───────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_STRIPE_PK=pk_test_...
REACT_APP_VAPID_PUBLIC_KEY=BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxYYY
